# Production Environment Variables Template
# 复制此文件为 .env.production.local 并填写实际值

# 环境
NODE_ENV=production
PORT=4000

# 数据库（Railway 会自动提供 ${{Postgres.DATABASE_URL}}）
DATABASE_URL=postgresql://user:password@host:5432/texas_prod

# Redis（Railway 会自动提供 ${{Redis.REDIS_URL}}）
REDIS_URL=redis://default:password@host:6379

# JWT 密钥（生成一个强随机字符串）
# 可以用: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# CORS 配置（生产环境改为实际域名）
CORS_ORIGIN=https://your-domain.vercel.app

# WebSocket CORS
SOCKET_CORS_ORIGIN=https://your-domain.vercel.app

# 区块链配置（可选）
BLOCKCHAIN_RPC_URL=
PRIVATE_KEY=

# 其他配置
LOG_LEVEL=info
