// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  nickname      String    @unique
  password      String
  avatar        String?
  role          String    @default("PLAYER") // PLAYER | ADMIN | SUPER_ADMIN
  status        String    @default("OFFLINE") // OFFLINE, ONLINE, PLAYING
  coinBalance   Float     @default(0)
  elo           Int       @default(1000) // Matchmaking ELO rating
  totalRake     Float     @default(0)    // Lifetime rake contributed (for Rakeback)
  rakebackBalance Float   @default(0)    // Accumulated Rakeback credits
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?

  // Email verification
  email                     String?    @unique
  emailVerified             Boolean    @default(false)
  emailVerificationCode     String?
  emailVerificationExpiry  DateTime?
  
  hasReceivedFirstDepositBonus Boolean  @default(false)
  wallet         Wallet?
  handsWon       Hand[]
  actions        HandAction[]
  transactions   Transaction[]
  adminLogs      AdminLog[]
  depositAddresses DepositAddress[]
  depositRecords   DepositRecord[]
  withdrawRequests WithdrawRequest[]
  withdrawAddresses WithdrawAddress[]

  sentFriends     Friend[]    @relation("FriendRequester")
  receivedFriends Friend[]    @relation("FriendAddressee")

  clubMemberships ClubMember[]
  ownedClubs      Club[]      @relation("ClubOwner")
  clubChats       ClubChat[]
  clubInviteCodes ClubInviteCode[] @relation("ClubInviteCreator")

  userMissions  UserMission[]
  depositBonuses DepositBonus[]

  @@map("users")
}

model AdminLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String   // BAN_USER | UNBAN_USER | ADJUST_BALANCE | DELETE_ROOM | KICK_USER | BROADCAST | MAINTENANCE
  targetType  String   // USER | ROOM | SYSTEM
  targetId    String?
  detail      String?
  createdAt   DateTime @default(now())

  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  balance       Float    @default(0)       // Real-money balance (reserved for future USDT top-up)
  chips         Float    @default(0)       // Game chips (migrated from old balance field)
  frozenChips   Float    @default(0)       // Chips locked at a table (prevents double-spend)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Room {
  id               String   @id @default(uuid())
  name             String
  blindSmall       Float
  blindBig         Float
  maxPlayers       Int
  minBuyIn         Float    @default(0)
  password         String?
  status           String   @default("ACTIVE") // ACTIVE, MAINTENANCE
  isMatchmaking    Boolean  @default(false)    // true = auto-created for quick-match
  isClubOnly       Boolean  @default(false)    // true = only accessible to club members
  isAnonymous      Boolean  @default(false)    // true = player identities are hidden
  tier             String?  // MICRO | LOW | MEDIUM | HIGH | PREMIUM
  isTournament     Boolean  @default(false)    // true = SNG/MTT/Blast tournament room
  tournamentConfig Json?                       // TournamentConfig JSON (SNG/MTT settings)
  isBlast          Boolean  @default(false)    // true = Blast instant tournament
  blastConfig      Json?                       // BlastConfig JSON
  createdAt        DateTime @default(now())

  tables      Table[]
  clubId      String?
  club        Club?    @relation(fields: [clubId], references: [id], onDelete: SetNull)

  @@map("rooms")
}

model Table {
  id             String   @id @default(uuid())
  roomId         String
  state          String   @default("WAITING") // WAITING, DEALING, PREFLOP, FLOP, TURN, RIVER, SHOWDOWN
  stateSnapshot  String?
  snapshotUpdatedAt DateTime?
  room           Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  hands          Hand[]

  @@map("tables")
}

model Hand {
  id        String   @id @default(uuid())
  tableId   String
  winnerId  String?
  potSize   Float    @default(0)
  rake      Float    @default(0)     // Total rake deducted this hand
  rakePercent Float  @default(0)     // Rake percentage applied
  createdAt DateTime @default(now())
  
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  winner    User?    @relation(fields: [winnerId], references: [id], onDelete: SetNull)
  actions   HandAction[]
  settlements Settlement[]

  @@map("hands")
  @@index([tableId])
  @@index([winnerId, createdAt])
  @@index([createdAt])
}

model HandAction {
  id        String   @id @default(uuid())
  handId    String
  userId    String
  action    String   // FOLD, CHECK, CALL, RAISE, ALLIN
  amount    Float    @default(0)
  createdAt DateTime @default(now())

  hand      Hand     @relation(fields: [handId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("hand_actions")
  @@index([handId, createdAt])
  @@index([userId, createdAt])
}

model Settlement {
  id        String   @id @default(uuid())
  handId    String
  userId    String
  amount    Float
  rakeAmount Float   @default(0)   // User's share of the rake (for Rakeback tracking)
  createdAt DateTime @default(now())

  hand      Hand     @relation(fields: [handId], references: [id], onDelete: Cascade)

  @@map("settlements")
  @@index([handId])
  @@index([userId, createdAt])
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  type      String   // DEPOSIT, WITHDRAW, GAME_WIN, GAME_LOSS
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
  @@index([userId, type])
  @@index([userId, createdAt])
}

model DepositAddress {
  id        String   @id @default(uuid())
  userId    String
  address   String
  label     String?
  isDefault Boolean  @default(false)
  index     Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
  @@map("deposit_addresses")
}

model DepositRecord {
  id        String   @id @default(uuid())
  userId    String
  txHash    String   @unique
  amount    Float    // USDT 金额
  chips     Float    // 兑换的筹码
  status    String   @default("CONFIRMED")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deposit_records")
}

model WithdrawAddress {
  id        String   @id @default(uuid())
  userId    String
  address   String
  label     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
  @@map("withdraw_addresses")
}

// Tracks the last block number scanned by pollDeposits to avoid missing events
// due to sliding-window gaps or RPC indexing lag
model ScanCursor {
  id            String   @id @default("singleton")
  lastBlock     BigInt   @default(0)
  updatedAt     DateTime @default(now())

  @@map("scan_cursors")
}

model WithdrawRequest {
  id            String    @id @default(uuid())
  userId        String
  amountChips   Float
  amountUsdt    Float
  toAddress     String    // ETH address to receive USDT
  fromAddress   String?   // System owner wallet used for transfer (set when tx is executed)
  status        String    @default("PENDING") // PENDING | PROCESSING | CONFIRMED | FAILED
  txHash        String?
  failureReason String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("withdraw_requests")
  @@index([userId, status])
  @@index([status, createdAt])
  @@index([fromAddress, createdAt])
}

model Friend {
  id          String   @id @default(uuid())
  requesterId String
  addresseeId String
  status      String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | BLOCKED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester   User     @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User     @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@map("friends")
}

model Club {
  id          String   @id @default(uuid())
  name        String
  description String?
  ownerId     String
  avatar      String?
  status      String   @default("ACTIVE") // ACTIVE, BANNED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User         @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     ClubMember[]
  rooms       Room[]
  chats       ClubChat[]
  inviteCodes ClubInviteCode[]

  @@map("clubs")
}

model ClubMember {
  id        String   @id @default(uuid())
  clubId    String
  userId    String
  role      String   @default("MEMBER") // OWNER, ADMIN, MEMBER
  joinedAt  DateTime @default(now())

  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@map("club_members")
}

model ClubChat {
  id        String   @id @default(uuid())
  clubId    String
  userId    String
  message   String
  createdAt DateTime @default(now())

  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt])
  @@map("club_chats")
}

model ClubInviteCode {
  id         String    @id @default(uuid())
  clubId     String
  code       String    @unique  // 6-char uppercase alphanumeric, no 0/O/1/I/L
  creatorId  String
  maxUses    Int       @default(1)    // 0 = unlimited
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  isActive   Boolean   @default(true)

  club       Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  creator    User      @relation("ClubInviteCreator", fields: [creatorId], references: [id])

  @@index([clubId])
  @@index([code])
}

// ── Missions ────────────────────────────────────────────────────────────────

// Defines every mission available in the game.
// type: ONE_TIME | DAILY | WEEKLY
// periodType: DAY | WEEK | null (null = not a recurring mission)
// Each mission has a fixed chip reward paid out when the user completes it.
model Mission {
  id          String   @id @default(uuid())
  key         String   @unique // P1-FIRST-DEPOSIT | P1-DAILY-PLAY | P2-WEEKLY-WINS | etc.
  title       String
  description String
  type        String   // ONE_TIME | DAILY | WEEKLY
  periodType  String?  // DAY | WEEK | null (null only for ONE_TIME)
  rewardChips Float
  target      Int      @default(1) // e.g. deposit 1 time, play 3 hands, win 5 hands
  createdAt   DateTime @default(now())

  userMissions UserMission[]

  @@map("missions")
}

// Tracks per-user mission state: completion status, progress, period tracking, and rewards claimed.
// For DAILY/WEEKLY missions, a new UserMission row is created each period.
model UserMission {
  id          String    @id @default(uuid())
  userId      String
  missionId   String
  status      String    @default("ACTIVE") // ACTIVE | COMPLETED | CLAIMED | EXPIRED
  progress    Int       @default(0)
  completedAt DateTime?
  claimedAt   DateTime?
  periodStart DateTime  @default(now()) // Start of the period this record belongs to (midnight UTC for daily, Monday UTC for weekly)
  createdAt   DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  // Unique per user+mission+period to allow multiple UserMission rows for recurring missions
  @@unique([userId, missionId, periodStart])
  @@map("user_missions")
}

// Tracks a user's first-deposit bonus and its wagering (rollover) progress.
// When a user makes their first deposit, a DepositBonus record is created with
// the bonus chips awarded by the P1-FIRST-DEPOSIT mission. The user must wager
// (risk at the poker table) a multiple of the bonus amount before the bonus
// is unlocked and becomes withdrawable.
model DepositBonus {
  id                    String    @id @default(uuid())
  userId                String    @unique // One bonus per user
  depositAmount         Float     // The USDT deposit amount that triggered the bonus
  bonusAmount           Float     // Chip bonus awarded (mirrors mission reward)
  wageringRequirement  Float     // Total chips that must be wagered (e.g. 5× bonusAmount)
  wageringProgress      Float     @default(0) // Chips wagered so far toward the requirement
  status                String    @default("ACTIVE") // ACTIVE | COMPLETED | CANCELLED
  createdAt             DateTime  @default(now())
  completedAt           DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deposit_bonuses")
}

// ═══════════════════════════════════════════════════════════════════════════
// Notification
// ═══════════════════════════════════════════════════════════════════════════

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "friend_online" | "club_tournament_starting" | ...
  title     String
  body      String
  metadata  Json?    // 类型相关的额外数据
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, read, createdAt(sort: Desc)])
}
