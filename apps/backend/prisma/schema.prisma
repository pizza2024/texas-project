// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  nickname      String    @unique
  password      String
  avatar        String?
  role          String    @default("PLAYER") // PLAYER | ADMIN | SUPER_ADMIN
  status        String    @default("OFFLINE") // OFFLINE, ONLINE, PLAYING
  coinBalance   Float     @default(0)
  elo           Int       @default(1000) // Matchmaking ELO rating
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?

  // Email verification
  email                     String?    @unique
  emailVerified             Boolean    @default(false)
  emailVerificationCode     String?
  emailVerificationExpiry  DateTime?
  
  wallet         Wallet?
  handsWon       Hand[]
  actions        HandAction[]
  transactions   Transaction[]
  adminLogs      AdminLog[]
  depositAddress DepositAddress?
  depositRecords DepositRecord[]
  withdrawRequests WithdrawRequest[]

  sentFriends     Friend[]    @relation("FriendRequester")
  receivedFriends Friend[]    @relation("FriendAddressee")

  @@map("users")
}

model AdminLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String   // BAN_USER | UNBAN_USER | ADJUST_BALANCE | DELETE_ROOM | KICK_USER | BROADCAST | MAINTENANCE
  targetType  String   // USER | ROOM | SYSTEM
  targetId    String?
  detail      String?
  createdAt   DateTime @default(now())

  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @unique
  balance       Float    @default(0)       // Real-money balance (reserved for future USDT top-up)
  chips         Float    @default(0)       // Game chips (migrated from old balance field)
  frozenChips   Float    @default(0)       // Chips locked at a table (prevents double-spend)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Room {
  id            String   @id @default(uuid())
  name          String
  blindSmall    Float
  blindBig      Float
  maxPlayers    Int
  minBuyIn      Float    @default(0)
  password      String?
  status        String   @default("ACTIVE") // ACTIVE, MAINTENANCE
  isMatchmaking Boolean  @default(false)    // true = auto-created for quick-match
  tier          String?  // MICRO | LOW | MEDIUM | HIGH | PREMIUM
  createdAt     DateTime @default(now())
  
  tables      Table[]

  @@map("rooms")
}

model Table {
  id             String   @id @default(uuid())
  roomId         String
  state          String   @default("WAITING") // WAITING, DEALING, PREFLOP, FLOP, TURN, RIVER, SHOWDOWN
  stateSnapshot  String?
  snapshotUpdatedAt DateTime?
  room           Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  hands          Hand[]

  @@map("tables")
}

model Hand {
  id        String   @id @default(uuid())
  tableId   String
  winnerId  String?
  potSize   Float    @default(0)
  createdAt DateTime @default(now())
  
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  winner    User?    @relation(fields: [winnerId], references: [id], onDelete: SetNull)
  actions   HandAction[]
  settlements Settlement[]

  @@map("hands")
}

model HandAction {
  id        String   @id @default(uuid())
  handId    String
  userId    String
  action    String   // FOLD, CHECK, CALL, RAISE, ALLIN
  amount    Float    @default(0)
  createdAt DateTime @default(now())

  hand      Hand     @relation(fields: [handId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("hand_actions")
  @@index([handId])
  @@index([userId])
}

model Settlement {
  id        String   @id @default(uuid())
  handId    String
  userId    String
  amount    Float
  createdAt DateTime @default(now())

  hand      Hand     @relation(fields: [handId], references: [id], onDelete: Cascade)

  @@map("settlements")
  @@index([handId])
  @@index([userId])
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Float
  type      String   // DEPOSIT, WITHDRAW, GAME_WIN, GAME_LOSS
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
  @@index([userId, type])
  @@index([userId, createdAt])
}

model DepositAddress {
  id        String   @id @default(uuid())
  userId    String   @unique
  address   String   @unique
  index     Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deposit_addresses")
}

model DepositRecord {
  id        String   @id @default(uuid())
  userId    String
  txHash    String   @unique
  amount    Float    // USDT 金额
  chips     Float    // 兑换的筹码
  status    String   @default("CONFIRMED")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("deposit_records")
}

// Tracks the last block number scanned by pollDeposits to avoid missing events
// due to sliding-window gaps or RPC indexing lag
model ScanCursor {
  id            String   @id @default("singleton")
  lastBlock     BigInt   @default(0)
  updatedAt     DateTime @default(now())

  @@map("scan_cursors")
}

model WithdrawRequest {
  id            String    @id @default(uuid())
  userId        String
  amountChips   Float
  amountUsdt    Float
  toAddress     String    // ETH address to receive USDT
  fromAddress   String?   // System owner wallet used for transfer
  status        String    @default("PENDING") // PENDING | PROCESSING | CONFIRMED | FAILED
  txHash        String?
  failureReason String?
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("withdraw_requests")
  @@index([userId, status])
  @@index([status, createdAt])
}

model Friend {
  id          String   @id @default(uuid())
  requesterId String
  addresseeId String
  status      String   @default("PENDING") // PENDING | ACCEPTED | REJECTED | BLOCKED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester   User     @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User     @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@map("friends")
}
