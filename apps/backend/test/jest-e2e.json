{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@texas/shared$": "<rootDir>/../../../packages/shared/src/index.ts",
    "^@texas/shared/validation$": "<rootDir>/../../../packages/shared/src/validation.ts",
    "^@texas/shared/types/tournament$": "<rootDir>/../../../packages/shared/src/types/tournament.ts",
    "^@/(.*)$": "<rootDir>/src/$1"
  },
  "setupFiles": ["<rootDir>/../test/setup-dotenv.ts"]
}
