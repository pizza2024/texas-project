# Copy this file and fill in values for your environment.
# For production deployment (Railway / Render / etc.), set these as environment variables.

NODE_ENV=production
PORT=4000
DATABASE_URL="postgresql://user:password@host:5432/texas_prod"
JWT_SECRET="your-strong-random-jwt-secret-at-least-32-chars"
REDIS_URL="redis://default:password@host:6379"

# ETH Deposit (Sepolia Testnet)
ETH_RPC_URL=https://rpc.sepolia.org
HD_WALLET_MNEMONIC=your-12-word-mnemonic-here
USDT_CONTRACT_ADDRESS=0x...usdt-contract-on-sepolia
USDT_DECIMALS=6
USDT_TO_CHIPS_RATE=100
DEPOSIT_MIN_CONFIRMATIONS=1
DEPOSIT_POLL_INTERVAL_MS=30000
