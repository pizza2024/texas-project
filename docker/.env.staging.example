# Lightsail Staging Environment Configuration
# Copy this file to docker/.env.staging and update values for your Lightsail setup

# ============================================
# Backend Configuration
# ============================================
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://texas:texas_password@postgres:5432/texas_staging?schema=public
REDIS_URL=redis://redis:6379

# Security: Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_RANDOM_VALUE_ON_LIGHTSAIL
JWT_EXPIRES_IN=7d

# CORS configuration (restrict to your domains)
# For local testing: http://localhost:3000,http://localhost:3001
# For Lightsail: https://web.not-replaced-yet.com,https://admin.not-replaced-yet.com
CORS_ORIGIN=https://web.not-replaced-yet.com,https://admin.not-replaced-yet.com
SOCKET_CORS_ORIGIN=https://web.not-replaced-yet.com,https://admin.not-replaced-yet.com

# ============================================
# Frontend Configuration (Web & Admin)
# ============================================
# API endpoint (should point to your api subdomain)
# Local: http://localhost:4000
# Lightsail: https://api.not-replaced-yet.com
NEXT_PUBLIC_API_URL=https://api.not-replaced-yet.com

# ============================================
# Mobile Configuration (if using Expo)
# ============================================
# Set to match backend API URL
EXPO_PUBLIC_API_URL=https://api.not-replaced-yet.com
