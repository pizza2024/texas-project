{
  "name": "texas-project-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo clean",
    "docker:local:up": "docker compose -f docker-compose.yml -f docker-compose.local.yml up -d --build",
    "docker:local:down": "docker compose -f docker-compose.yml -f docker-compose.local.yml down",
    "docker:staging:up": "docker compose --env-file docker/.env.staging up -d --build",
    "docker:staging:down": "docker compose --env-file docker/.env.staging down",
    "docker:remote:up": "docker compose -f docker-compose.remote.yml --env-file docker/.env.staging up -d",
    "docker:remote:down": "docker compose -f docker-compose.remote.yml --env-file docker/.env.staging down"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "expo-router": "~55.0.7",
    "prettier": "^3.0.0",
    "turbo": "latest"
  },
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "axios": "^1.13.5",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0"
  }
}
